---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <header class="nav">
    <a class="logo" href="/">
      <span class="brand-name">Astradic</span>
    </a>
    <div class="nav-links">
      <a class="btn btn-primary" style="color: #fff;" href="https://forms.fillout.com/t/bW7CakbWKCus">Get early access</a>
    </div>
  </header>

  <main>
    <section class="hero">
      <div>
        <h1 class="fade-in delayed">Block distractions. Reclaim your focus.</h1>
        <p class="lede fade-in more-delayed" style="margin-top: 10px;">
          Astradic locks distracting apps and sites, enforces limits, and keeps your attention where it matters.
        </p>
        <div class="cta-row fade-in more-delayed">
          <a class="btn btn-primary" style="color: #fff;" href="https://forms.fillout.com/t/bW7CakbWKCus">Get early access</a>
          <a class="btn btn-ghost" href="mailto:contact@astradic.org">Contact</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div style="display:flex; align-items:center; justify-content:space-between; gap:12px; flex-wrap:wrap;">
      <div style="display:flex; align-items:center; gap:10px;">
        <strong class="brand-name">Astradic</strong>
        <span style="color:var(--muted);">Screen time blocking</span>
      </div>
      <div class="footer-links">
        <a href="/terms">Terms</a>
        <a href="/privacy">Privacy</a>
        <a href="https://www.instagram.com/astradic_org">@astradic_org</a>
        <span>© {new Date().getFullYear()} Astradic. All rights reserved.</span>
      </div>
    </div>
  </footer>
</BaseLayout>
