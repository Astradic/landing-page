---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteNav from "../components/SiteNav.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<BaseLayout
  title="Astradic | Screen time blocking app"
  description="Astradic is a screen time blocking app that locks distracting apps and sites, enforces limits, and protects your focus."
>
  <SiteNav currentPath={Astro.url?.pathname ?? "/"} />

  <main>
    <section class="hero">
      <div>
        <span class="pill">Screen time blocking, redesigned</span>
        <h1 class="fade-in delayed">Block distractions. Reclaim your focus.</h1>
        <p class="lede fade-in more-delayed" style="margin-top: 10px;">
          Astradic locks distracting apps and sites, enforces limits, and keeps your attention where it matters.
        </p>
        <div class="cta-row fade-in more-delayed">
          <a class="btn btn-primary" href="https://forms.fillout.com/t/bW7CakbWKCus">Get early access</a>
          <a class="btn btn-ghost" href="mailto:contact@astradic.org">Contact</a>
        </div>
      </div>
      <div class="hero-card fade-in more-delayed">
        <div class="hero-grid">
          <div class="cell">
            <span class="tiny">Block lists</span>
            <strong>Apps + sites</strong>
            <p>Lock the biggest time sinks the moment you start a focus session.</p>
          </div>
          <div class="cell">
            <span class="tiny">Schedules</span>
            <strong>Automatic focus</strong>
            <p>Set recurring windows that protect your deep work every day.</p>
          </div>
          <div class="cell">
            <span class="tiny">Limits</span>
            <strong>Hard boundaries</strong>
            <p>Stop doomscrolling with firm caps and intentional unlocks.</p>
          </div>
          <div class="cell">
            <span class="tiny">Insights</span>
            <strong>Focus signals</strong>
            <p>Review your patterns and tighten what drains your attention.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="page-header">
        <span class="pill">App preview</span>
        <h2 class="page-title">A calm interface for serious focus</h2>
        <p class="page-lede">
          Every screen is designed to surface what's essential and remove the rest. These previews show
          how Astradic keeps your attention on the work.
        </p>
      </div>
    </section>

    <section class="section app-preview" id="preview">
      <div class="app-preview-grid">
        <div class="app-preview-visual">
          <div class="app-frame">
            <img
              class="app-screen"
              src="/app-display.png"
              alt="Astradic app home screen preview"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
        <div class="app-preview-copy">
          <span class="pill">Home</span>
          <h2>Your focus hub at a glance</h2>
          <p>
            See what is running, what is next, and how your recent sessions are trending without digging
            into menus.
          </p>
          <div class="app-preview-points">
            <div class="app-point">
              <span class="dot-small" aria-hidden="true"></span>
              <div>
                <strong>Active session + next up</strong>
                <p>Current focus, upcoming block, and timing in one view.</p>
              </div>
            </div>
            <div class="app-point">
              <span class="dot-small" aria-hidden="true"></span>
              <div>
                <strong>Friends</strong>
                <p>Light social context with streaks alongside your day.</p>
              </div>
            </div>
            <div class="app-point">
              <span class="dot-small" aria-hidden="true"></span>
              <div>
                <strong>Quick insights</strong>
                <p>Recent sessions and screen-time cues at a glance.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section app-preview app-preview-alt" id="preview-2">
      <div class="app-preview-grid">
        <div class="app-preview-copy">
          <span class="pill">Blocks</span>
          <h2>Build schedule blocks in seconds</h2>
          <p>
            Create recurring focus windows with clear durations and quick adjustments. Your routine stays
            visible and easy to update.
          </p>
          <div class="app-preview-points">
            <div class="app-point">
              <span class="dot-small" aria-hidden="true"></span>
              <div>
                <strong>Recurring sessions</strong>
                <p>Set daily or weekday blocks with a single tap.</p>
              </div>
            </div>
            <div class="app-point">
              <span class="dot-small" aria-hidden="true"></span>
              <div>
                <strong>Fast edits</strong>
                <p>Adjust, duplicate, or remove blocks instantly.</p>
              </div>
            </div>
            <div class="app-point">
              <span class="dot-small" aria-hidden="true"></span>
              <div>
                <strong>Daily limits</strong>
                <p>Add thresholds that trigger auto‑blocking.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="app-preview-visual">
          <div class="app-frame">
            <img
              class="app-screen"
              src="/app-display-2.png"
              alt="Astradic blocks schedule screen preview"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="section app-preview app-preview-stack" id="preview-3">
      <div class="app-preview-grid">
        <div class="app-preview-visual">
          <div class="app-frame">
            <img
              class="app-screen"
              src="/app-display-3.png"
              alt="Astradic focus timer screen preview"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
        <div class="app-preview-copy">
          <span class="pill">Focus timer</span>
          <h2>Timer or Pomodoro, ready to start</h2>
          <p>
            Choose your block list, set minutes, and switch between Timer and Pomodoro in one place.
          </p>
          <div class="app-preview-points">
            <div class="app-point">
              <span class="dot-small" aria-hidden="true"></span>
              <div>
                <strong>Block list selector</strong>
                <p>Pick the list tied to the session.</p>
              </div>
            </div>
            <div class="app-point">
              <span class="dot-small" aria-hidden="true"></span>
              <div>
                <strong>Minute dial</strong>
                <p>Quick presets with precise control.</p>
              </div>
            </div>
            <div class="app-point">
              <span class="dot-small" aria-hidden="true"></span>
              <div>
                <strong>Pomodoro controls</strong>
                <p>Toggle modes and set break length.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
